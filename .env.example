# hitobito-Instanz URL (ohne abschliessenden Slash)
VITE_HITOBITO_URL=https://jubla.puzzle.ch

# OAuth2 Client-ID (in hitobito registriert)
VITE_OAUTH_CLIENT_ID=
# OAuth2 Client-Secret (in hitobito registriert, optional bei Public Clients)
VITE_OAUTH_CLIENT_SECRET=

# ntfy-Server (Standard: öffentliches ntfy.sh)
VITE_NTFY_BASE_URL=https://ntfy.sh

# Base-Pfad für GitHub Pages (z.B. /hitobito-ntfy/ wenn Repo so heisst)
VITE_BASE_URL=/
